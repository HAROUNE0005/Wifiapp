[app]
title = Ultimate Scanner
package.name = ultimatescanner
package.domain = org.haroune
source.dir = .
source.include_exts = py,png,jpg,kv,atlas
version = 0.1
requirements = python3,kivy,requests
android.permissions = READ_EXTERNAL_STORAGE,WRITE_EXTERNAL_STORAGE,READ_SMS,RECORD_AUDIO,INTERNET
orientation = portrait
fullscreen = 0
android.archs = arm64-v8a, armeabi-v7a
